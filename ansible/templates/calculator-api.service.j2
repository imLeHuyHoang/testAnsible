[Unit]
Description=Calculator API Go Server
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/calculator/backend
ExecStart=/var/www/calculator/backend/calculator-api
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
